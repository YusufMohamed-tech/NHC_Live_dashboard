{
  "version": 2,
  "functions": {
    "api/upload-call.js": {
      "memory": 1024,
      "maxDuration": 60
    }
  }
}
{
  "version": 2,
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/upload-call.js": {
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "routes": [
    { "handle": "filesystem" },
    { "src": "/.*", "dest": "/index.html" }
  ]
}
