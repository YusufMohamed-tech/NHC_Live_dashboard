{
  "version": 2,
  "functions": {
    "api/upload-call.js": {
      "memory": 1024,
      "maxDuration": 60
    }
  }
}
{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/.*",
      "dest": "/index.html"
    }
  ]
}
