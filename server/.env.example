# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_RECORDINGS_TABLE=call_recordings

# Google Service Account credentials
# Option A: set client email and private key directly
GOOGLE_SERVICE_ACCOUNT_CLIENT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# Option B (alternative): set full JSON as base64 in GOOGLE_SERVICE_ACCOUNT_JSON_B64
# GOOGLE_SERVICE_ACCOUNT_JSON_B64=

# Google Drive folder where recordings will be uploaded
GOOGLE_DRIVE_FOLDER_ID=

# Upload limits
MAX_FILE_SIZE_BYTES=10485760
UPLOAD_FIELD_NAME=file

# Server
PORT=3000
LOG_LEVEL=info
